.env
.env.*
!.env.example
!apps/web/.env.example
.venv/
__pycache__/
*.py[cod]
*.log
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
ErrorReports/
node_modules/
apps/web/node_modules/
apps/web/dist/

# Local notes and terminal scratch files
ignore-*.md

# Project/customer data is confidential by default.
data/**
!data/
!data/**/
!data/**/.gitkeep

# Confidential source documents must never be committed accidentally.
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.xlsm
*.ppt
*.pptx

# Database dumps and backups.
*.dump
*.backup
*.bak
*.sql.gz
*.dump.gz
*.tar
*.zip
*.7z
dumps/
backups/
